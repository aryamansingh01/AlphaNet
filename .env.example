# ============================================
# AlphaNet - Environment Variables
# Copy this to .env and fill in your keys
# ============================================

# MODE: "backtest" or "paper_trade"
# backtest    = run strategies on historical data (no trading keys needed)
# paper_trade = execute signals via Alpaca paper trading
MODE=backtest

# FRED (Federal Reserve Economic Data) — REQUIRED
# Get free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Financial Modeling Prep — REQUIRED
# Get free key: https://financialmodelingprep.com/developer
FMP_API_KEY=

# Finnhub — REQUIRED
# Get free key: https://finnhub.io/register
FINNHUB_API_KEY=

# Reddit (PRAW) — OPTIONAL (for sentiment signals)
# Get free key: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AlphaNet/1.0

# Alpaca — ONLY needed if MODE=paper_trade
# Get free key: https://app.alpaca.markets/signup
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./alphanet.db
